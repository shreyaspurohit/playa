# === FETCHED CAMP DATA — deliberately not committed ===
# The repo is public; the fetched camp content (owned by individual camps
# per the directory.burningman.org ToS) must not live in git history.
# All of these files are regenerated on every CI run on the ephemeral
# GH Actions runner, uploaded as a Pages artifact, then evaporate.
data/pages/
data/pages-backups/
data/meta.json
data/camps.csv
data/camps_tagged.csv
data/logs/

# === GENERATED SITE — not committed either ===
# site/index.html contains the (encrypted) fetched payload. site/sw.js
# is regenerated each build to tie cache keys to the build version.
# Both built on the runner, uploaded via actions/upload-pages-artifact,
# deployed from there. site/CNAME, site/robots.txt, site/.nojekyll,
# site/manifest.webmanifest, site/icon.svg stay committed —
# they're config + PWA shell assets, not data.
site/index.html
site/sw.js
site/version.txt

# === BRC map data from /update-map skill — never commit ===
# The skill downloads measurements PDF / city plan PDF / GeoJSON /
# KMZ to /tmp/brc-<YEAR>/, not the repo. These rules are
# belt-and-suspenders: if anything binary-map-shaped leaks into the
# tree (wrong cwd, a manual download), git won't pick it up.
*.pdf
*.kml
*.kmz
*.mbtiles
*.geojson
*.shp
*.dbf

# === Client toolchain ===
# node_modules is restored by `npm ci` in CI; bundle.js is regenerated
# on every build. Keep only source + config in git.
client/node_modules/
client/dist/

# === Python build artifacts (from `pip install -e ./backend`) ===
backend/src/*.egg-info/
backend/build/
*.egg-info/

# === Standard ignores ===
__pycache__/
*.pyc
.DS_Store

# Local overrides. Put real SITE_PASSWORD / CONTACT_EMAIL in env or a repo
# secret, not in the tree.
.env
.env.local
